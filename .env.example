# ── HCMC 3D Building Tiles — Frontend Configuration ──

# Backend API base URL (no trailing slash)
# In dev, Vite proxy handles /api → backend, so leave empty
# In production, set to your backend URL e.g. https://api.yourdomain.com
VITE_API_BASE_URL=https://api.yourdomain.com

# App metadata
VITE_APP_TITLE=HCMC GIS Building
VITE_APP_DESCRIPTION=Download MVT building tiles from Ho Chi Minh City from bando.tphcm.gov.vn server into MBTiles format
VITE_APP_URL=https://api.yourdomain.com

# Social / contact links
VITE_GITHUB_URL=https://github.com/author/repo
VITE_CONTACT_EMAIL=email@gmail.com
VITE_TWITTER_URL=
VITE_FACEBOOK_URL=
